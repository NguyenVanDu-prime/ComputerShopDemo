<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterAccountToDBServlet</servlet-name>
        <servlet-class>servlet.RegisterAccountToDBServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>getAccountsByFirstLetterServlet</servlet-name>
        <servlet-class>servlet.getAccountsByFirstLetterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>getAccountsByFirstLetter</servlet-name>
        <servlet-class>getAccountsByFirstLetter</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>getComputerByLetterServlet</servlet-name>
        <servlet-class>servlet.getComputerByLetterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>servlet.MainController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterAccountToDBServlet</servlet-name>
        <url-pattern>/RegisterAccountToDBServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>getAccountsByFirstLetterServlet</servlet-name>
        <url-pattern>/getAccountsByFirstLetterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>getAccountsByFirstLetter</servlet-name>
        <url-pattern>/getAccountsByFirstLetter</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>getComputerByLetterServlet</servlet-name>
        <url-pattern>/getComputerByLetterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MainController</servlet-name>
        <url-pattern>/MainController</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>MainController</welcome-file>
    </welcome-file-list>
</web-app>
